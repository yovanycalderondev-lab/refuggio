# ════════════════════════════════════════════════════════════════
# REFUGIO v3 — Variables de entorno
# Backend: Railway  |  Frontend: Vercel  |  DB: Supabase
# ════════════════════════════════════════════════════════════════
# Copia este archivo como .env y rellena los valores

# ── Supabase ──────────────────────────────────────────────────
# Obtén estos en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Ollama ────────────────────────────────────────────────────
# Ollama Cloud: obtén tu key en ollama.com/settings/api-keys
# Ollama local: deja OLLAMA_API_KEY vacío y pon la URL de tu servidor
OLLAMA_URL=https://api.ollama.com
11907ebfb20f46288a8ca63141d5e155.YPsXtNiGhzajx_g3QZKOnhFo

# Modelo a usar (eficiente y ligero):
OLLAMA_MODEL=llama3.2

# ── Servidor ─────────────────────────────────────────────────
PORT=3000

# ── CORS ─────────────────────────────────────────────────────
# Pon aquí la URL de tu frontend en Vercel (sin slash final)
# Ejemplo: https://refugio.vercel.app
# Para desarrollo local: *
ALLOWED_ORIGINS=*
